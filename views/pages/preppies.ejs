<audio id="gang-theme" loop preload="auto">
    <source src="/audio/preppies-theme.mp3" type="audio/mpeg">
</audio>

<script>
    const navLinks = document.querySelectorAll(".gang-file-nav a[href^='#']");
    const sections = document.querySelectorAll(".gang-section");

    window.addEventListener("scroll", () => {
        let current = "";

        sections.forEach(section => {
            const sectionTop = section.offsetTop - 180;

            if(window.scrollY >= sectionTop){
                current = section.getAttribute("id");
            }
        });

        navLinks.forEach(link => {
            link.classList.remove("active");

            if(link.getAttribute("href") === "#" + current){
                link.classList.add("active");
            }
        });
    });

    const gangToggle = document.getElementById("gang-music-toggle");
    const gangText = document.querySelector(".gang-music-display strong");
    const gangAudio = document.getElementById("gang-theme");

    gangAudio.volume = 0.25;

    let gangPlaying = false;

    gangToggle.addEventListener("click", () => {
        if(!gangPlaying){
            gangAudio.play();

            gangText.textContent = "PREPPIES THEME : PLAYING";
            gangToggle.textContent = "❚❚";

            gangPlaying = true;
        }else{
            gangAudio.pause();

            gangText.textContent = "PREPPIES THEME : PAUSED";
            gangToggle.textContent = "▶";

            gangPlaying = false;
        }
    });
</script>

