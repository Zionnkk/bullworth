<audio id="gang-music" src="/audio/greasers-theme.mp3" loop></audio>

<script>
    const navLinks = document.querySelectorAll(".gang-file-nav a[href^='#']");
    const sections = document.querySelectorAll(".gang-section");

    window.addEventListener("scroll", () => {
        let current = "";

        sections.forEach(section => {
            const sectionTop = section.offsetTop - 180;

            if(window.scrollY >= sectionTop){
                current = section.getAttribute("id");
            }
        });

        navLinks.forEach(link => {
            link.classList.remove("active");

            if(link.getAttribute("href") === "#" + current){
                link.classList.add("active");
            }
        });
    });

    const gangToggle = document.getElementById("gang-music-toggle");
    const gangAudio = document.getElementById("gang-music");

    gangAudio.volume = 0.25;

    window.addEventListener("load", () => {
        gangAudio.play().catch(() => {});
    });

    gangToggle.addEventListener("click", () => {
        if(gangAudio.paused){
            gangAudio.play();
        }else{
            gangAudio.pause();
        }
    });
</script>

