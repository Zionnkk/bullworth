<script src="/js/script.js"></script>
<script src="/js/main.js"></script>
<div id="report-transition">

    <audio id="global-menu-click" preload="auto">
    <source src="/audio/menu-click.mp3" type="audio/mpeg">
</audio>

<script>
    const globalClickSound = document.getElementById("global-menu-click");

    if(globalClickSound){
        globalClickSound.volume = 0.55;

        document.querySelectorAll("a, button").forEach(item => {
            item.addEventListener("click", (e) => {
                const href = item.getAttribute("href");

                globalClickSound.currentTime = 0;
                globalClickSound.play().catch(() => {});

                if(item.tagName === "A" && href && href !== "#" && !href.startsWith("#")){
                    e.preventDefault();

                    setTimeout(() => {
                        window.location.href = href;
                    }, 650);
                }
            });
        });
    }
</script>
</script>

</div>
</body>
</html>